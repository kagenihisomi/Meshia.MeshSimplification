#!/usr/bin/env sh
set -eu

REPO_ROOT=$(git rev-parse --show-toplevel)
SCRIPT_PATH="$REPO_ROOT/tools/verify-package.ps1"

if [ ! -f "$SCRIPT_PATH" ]; then
  echo "[pre-commit] Missing verifier script: $SCRIPT_PATH" >&2
  exit 1
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT_PATH"
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT_PATH"
else
  echo "[pre-commit] Neither pwsh nor powershell is available in PATH." >&2
  exit 1
fi
